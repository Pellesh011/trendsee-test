              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "const jsonData = pm.response.json();",
                  "pm.test(\"Has access_token\", function () {",
                  "    pm.expect(jsonData).to.have.property('access_token');",
                  "});",
